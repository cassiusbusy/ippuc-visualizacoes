const CORES=["#00a859", "#F07E31", "#447EC0", "#EA535E", "#8E6CAD"];
const W=920,H=560;
const GPMAX=5.2855;

let thr=0.08,forca=100,dist=90,gmin=0,gpmin=0;
let tr={k:1,tx:0,ty:0},drag=null;
let nos,arestas;

function initNos(){
  nos=DALL.nos.map(n=>Object.assign({},n,{
    x:W/2+(Math.random()-.5)*320,y:H/2+(Math.random()-.5)*260,
    vx:0,vy:0,fixed:false
  }));
  arestas=DALL.arestas;
}

function noRadius(n){return 8+Math.min((n.grau_pond/GPMAX)*28,24);}

function aresVisiveis(){
  const nosVisiveis=new Set(nos.filter((n,i)=>n.grau>=gmin&&n.grau_pond>=gpmin).map((_,i)=>i));
  return arestas.filter(a=>a.weight>=thr&&nosVisiveis.has(a.source)&&nosVisiveis.has(a.target));
}

function nosVisiveis(){return nos.filter(n=>n.grau>=gmin&&n.grau_pond>=gpmin);}

// Cor da aresta pelo bridging: baixo bridging = cinza, alto = azul escuro
function bridgingColor(b){
  const t=Math.min(Math.max(b,0),1);
  const r=Math.round(224+(26-224)*t);
  const g=Math.round(224+(58-224)*t);
  const bl=Math.round(224+(92-224)*t);
  return `rgb(${r},${g},${bl})`;
}

function tick(){
  const nv=nosVisiveis();
  const av=aresVisiveis();
  for(let i=0;i<nv.length;i++){
    for(let j=i+1;j<nv.length;j++){
      const ni=nv[i],nj=nv[j];
      const dx=nj.x-ni.x,dy=nj.y-ni.y,d=Math.sqrt(dx*dx+dy*dy)||1;
      const f=forca/(d*d);
      ni.vx-=dx*f;ni.vy-=dy*f;nj.vx+=dx*f;nj.vy+=dy*f;
    }
  }
  av.forEach(a=>{
    const s=nos[a.source],t=nos[a.target];if(!s||!t)return;
    const dx=t.x-s.x,dy=t.y-s.y,d=Math.sqrt(dx*dx+dy*dy)||1;
    const f=(d-dist)*0.05*a.weight;
    s.vx+=dx/d*f;s.vy+=dy/d*f;t.vx-=dx/d*f;t.vy-=dy/d*f;
  });
  nv.forEach(n=>{n.vx+=(W/2-n.x)*0.004;n.vy+=(H/2-n.y)*0.004;});
  nv.forEach(n=>{
    if(n.fixed)return;
    n.vx*=0.83;n.vy*=0.83;
    n.x=Math.max(15,Math.min(W-15,n.x+n.vx));
    n.y=Math.max(15,Math.min(H-15,n.y+n.vy));
  });
  render();
}

function render(){
  const av=aresVisiveis();
  const nv=new Set(nosVisiveis().map(n=>n.id));
  const maxW=Math.max(...av.map(a=>a.weight),0.01);

  document.getElementById('links').innerHTML=av.map(a=>{
    const s=nos[a.source],t=nos[a.target];if(!s||!t)return'';
    const col=bridgingColor(a.bridging);
    const sw=0.5+a.weight/maxW*3.5;
    return `<line x1="${s.x}" y1="${s.y}" x2="${t.x}" y2="${t.y}"
      stroke="${col}" stroke-width="${sw}" stroke-opacity=".75"/>`;
  }).join('');

  document.getElementById('nodes').innerHTML=nos.map((n,i)=>{
    if(!nv.has(n.id))return'';
    const cor=CORES[n.topico]||'#ccc';
    const r=noRadius(n);
    return `<g data-i="${i}" style="cursor:pointer">
      <circle cx="${n.x}" cy="${n.y}" r="${r}" fill="${cor}" fill-opacity=".85" stroke="#fff" stroke-width="1.8"/>
      <text x="${n.x}" y="${n.y+3}" text-anchor="middle" font-size="${Math.max(6,r*.55)}" fill="white"
        font-family="Roboto,sans-serif" font-weight="700" pointer-events="none">${n.topico}</text>
    </g>`;
  }).join('');

  document.querySelectorAll('#nodes g').forEach(el=>{
    const i=parseInt(el.dataset.i);
    el.addEventListener('click',()=>mostrarInfo(i));
    el.addEventListener('mousedown',e=>{
      drag={i,ox:nos[i].x-e.offsetX/tr.k,oy:nos[i].y-e.offsetY/tr.k};
      nos[i].fixed=true;e.stopPropagation();
    });
  });
}

function mostrarInfo(i){
  const n=nos[i],cor=CORES[n.topico];
  const box=document.getElementById('ibox');
  document.getElementById('icontent').innerHTML=
    `<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
       <span style="font-weight:700;color:${cor}">${n.topico_nome}</span>
       <span class="mpill" style="background:${cor}22;color:${cor}">T${n.topico}</span>
     </div>
     <div style="font-family:monospace;font-size:.68rem;color:#888;margin-bottom:5px;">${n.submission_id.slice(0,24)}...</div>
     <div class="metrics-row">
       <span class="mpill" style="background:#eef2ff;color:var(--az)">Grau: ${n.grau}</span>
       <span class="mpill" style="background:#e8f5e9;color:#2e7d32">Grau pond.: ${n.grau_pond.toFixed(3)}</span>
       <span class="mpill" style="background:#f3f3f3;color:#555">Bridging: ${n.bridging.toFixed(4)}</span>
       <span class="mpill" style="background:#fff8e1;color:#e65100">Autor: ${n.email}</span>
     </div>
     <div style="font-size:.77rem;color:#333;margin-top:7px;line-height:1.5;">${n.conteudo}
       <button onclick="abrirCompleto(${i})" style="display:inline-block;margin-left:6px;padding:2px 8px;border-radius:4px;
         border:1px solid var(--v);background:var(--vl);color:var(--v);cursor:pointer;font-size:.7rem;font-family:Roboto,sans-serif;">
         Ver completo</button></div>`;
  box.classList.add('vis');
}

function abrirCompleto(i){
  const n=nos[i];
  am(n.topico_nome,`<b>ID:</b> ${n.submission_id}<br><b>Autor:</b> ${n.email}<br><b>Tipo:</b> ${n.tipo}<br><b>Grau:</b> ${n.grau} | <b>Grau pond.:</b> ${n.grau_pond.toFixed(3)} | <b>Bridging:</b> ${n.bridging.toFixed(4)}`,n.conteudo_completo||n.conteudo);
}

function renderLeg(){
  const el=document.getElementById('legenda');
  DALL.nomes_topicos.forEach((n,i)=>el.innerHTML+=`<div class="legi"><div class="legdot" style="background:${CORES[i]}"></div><span>${n}</span></div>`);
}

function resetar(){
  nos.forEach(n=>{n.x=W/2+(Math.random()-.5)*320;n.y=H/2+(Math.random()-.5)*260;n.vx=0;n.vy=0;n.fixed=false;});
}

// Controles
const svg=document.getElementById('gsvg');
svg.addEventListener('mousedown',e=>{if(!drag)drag={canvas:true,ox:e.offsetX-tr.tx,oy:e.offsetY-tr.ty};});
svg.addEventListener('mousemove',e=>{
  if(!drag)return;
  if(drag.canvas){tr.tx=e.offsetX-drag.ox;tr.ty=e.offsetY-drag.oy;document.getElementById('zg').setAttribute('transform',`translate(${tr.tx},${tr.ty}) scale(${tr.k})`);}
  else if(drag.i!==undefined){nos[drag.i].x=e.offsetX/tr.k+drag.ox;nos[drag.i].y=e.offsetY/tr.k+drag.oy;}
});
svg.addEventListener('mouseup',()=>{drag=null;});
svg.addEventListener('mouseleave',()=>{drag=null;});
svg.addEventListener('wheel',e=>{
  e.preventDefault();const s=e.deltaY<0?1.12:.9;
  tr.k=Math.max(.25,Math.min(4,tr.k*s));
  document.getElementById('zg').setAttribute('transform',`translate(${tr.tx},${tr.ty}) scale(${tr.k})`);
},{passive:false});

document.getElementById('forca').addEventListener('input',e=>{forca=parseInt(e.target.value);document.getElementById('fval').textContent=e.target.value;});
document.getElementById('dist').addEventListener('input',e=>{dist=parseInt(e.target.value);document.getElementById('dval').textContent=e.target.value;});
document.getElementById('thr').addEventListener('input',e=>{thr=parseInt(e.target.value)/100;document.getElementById('tval').textContent=thr.toFixed(2);});
document.getElementById('gmin').addEventListener('input',e=>{gmin=parseInt(e.target.value);document.getElementById('gval').textContent=e.target.value;});
document.getElementById('gpmin').addEventListener('input',e=>{gpmin=parseInt(e.target.value)/10;document.getElementById('gpval').textContent=gpmin.toFixed(1);});

function am(t,meta,b){document.getElementById("mt").textContent=t;document.getElementById("mi").innerHTML=meta;document.getElementById("mb").textContent=b;document.getElementById("modal").classList.add("open");}function fm(){document.getElementById("modal").classList.remove("open");}document.getElementById("modal").addEventListener("click",e=>{if(e.target===document.getElementById("modal"))fm();});
initNos();renderLeg();setInterval(tick,30);
</script></body></html>
